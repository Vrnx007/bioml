# Copy to `.env.local` and fill in values from your Supabase project (Settings → API).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Local one-shot: npm run seed:demo-users — creates demo Auth users + profiles.
# Copy from Supabase Dashboard → Settings → API → service_role (secret). Never commit or expose in the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: show list prices on the catalog without signing in (demo only).
# NEXT_PUBLIC_DEMO_SHOW_PRICES=true
